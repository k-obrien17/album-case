TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Temporary containment kill switch for all mutating API endpoints (ranking,
# atom, discover-artist). Must be exactly "true" to allow writes; anything
# else (unset, "false", etc.) blocks with a 503 before touching Turso or
# MusicBrainz. Remove once real owner-write authentication exists.
ALLOW_PUBLIC_WRITES=false
